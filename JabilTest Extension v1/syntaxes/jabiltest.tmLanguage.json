        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.jabiltest",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.jabiltest",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.jabiltest",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.jabiltest",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.decimal.jabiltest",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
