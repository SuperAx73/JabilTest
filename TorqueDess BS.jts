function Initialize_Screen()
{

  SetTestName("Initialize Screen Size");		//Se obtienen las dimensiones del monitor para deplegar las imagenes al 85%
  $Fail_Text = StringCat("Error al inicializar dimensiones del monitor","");
  // Get the screen size
  ($ScreenWidth,$ScreenHeight) = GetDisplaySize(0);
	// Make values for popup window
  $PopupWidth = $ScreenWidth * 0.85;
  $PopupWidth = Round($PopupWidth,0);
  UpdateStatus($PopupWidth);
  $PopupHeight = $ScreenHeight * 0.85;
  $PopupHeight = Round($PopupHeight,0);
  UpdateStatus($PopupHeight);
  $Width = New("Integer",$PopupWidth);
  $Height = New("Integer",$PopupHeight);
  $Popup_X = ($ScreenWidth - $PopupWidth)/2;
  $Popup_X = Round($Popup_X,0);
  $Popup_Y = ($ScreenHeight - $PopupHeight)/2;
  $Popup_Y = Round($Popup_Y,0);
  //~ $Y = $ScreenHeight/2;
  
  $Red1 = New ("Integer",0);			//Configura el color de JabilTest
  $Green1 = New ("Integer",128);
  $Blue1 = New ("Integer",128);
  $Red2 = New ("Integer",128);
  $Green2 = New ("Integer",128);
  $Blue2 = New ("Integer",128);
  $ColorAngle = New ("Integer",0);
  SetCellColor($Red1,$Green1,$Blue1,$Red2,$Green2,$Blue2,$ColorAngle);  
  return;
}

function UpdateProgress()
{
   //~ UpdateStatus($UpdateBar);		//Configura constantemente la progresion de la barra de acuerdo a la cantidad de tornillos a instalar
  if ($UpdateBar == 0)
  {
    $NumBar = Divide(100,$ScrewQuantity);
    $NumBar = Floor($NumBar);
    $UpdateBar = $NumBar;
    UpdateProgressBar($UpdateBar);  
    goto SkipBar;
  }
  
  if ($UpdateBar < 95)
  {
    $UpdateBar = $UpdateBar + $NumBar;  
      if ($UpdateBar > 100)
      {
	$UpdateBar = 95;
      }
    UpdateProgressBar($UpdateBar);    
  }
Label SkipBar:  
  
return;
}
function FailTorque()
{
  UpdateStatus($FailMessage);		//Muestra el mensaje de Abort en JabilTest
  $Red1 = New ("Integer",128);
  $Green1 = New ("Integer",64);
  $Blue1 = New ("Integer",0);
  $Red2 = New ("Integer",0);
  $Green2 = New ("Integer",64);
  $Blue2 = New ("Integer",128);
  $ColorAngle = New ("Integer",0);
  SetCellColor($Red1,$Green1,$Blue1,$Red2,$Green2,$Blue2,$ColorAngle);
  ConfigureReporting("HTML Report Writer",false);
  ConfigureReporting("MES Report Writer",false);
}
End;


function AbortTorque()
{
  UpdateStatus($AbortMessage);		//Muestra el mensaje de Abort en JabilTest
  $Red1 = New ("Integer",0);
  $Green1 = New ("Integer",64);
  $Blue1 = New ("Integer",128);
  $Red2 = New ("Integer",0);
  $Green2 = New ("Integer",64);
  $Blue2 = New ("Integer",128);
  $ColorAngle = New ("Integer",0);
  SetCellColor($Red1,$Green1,$Blue1,$Red2,$Green2,$Blue2,$ColorAngle);
  ConfigureReporting("HTML Report Writer",false);
  ConfigureReporting("MES Report Writer",false);
}
End;
//*********************************************************************************************************************************
//	CleanUpTest FUNCTION
//*********************************************************************************************************************************
function Cleanup()
{
  SetTestName("Cleanup Step");
  SetCellViewMode("BROWSER");
  UpdateStatus("\r\n Cleanup Step =================================");  
  UpdateProgressBar(100);  
  SetExtendedPanelMode("NONE");  
  SetDebugVerbosityLevel("None");  
  SleepMilliseconds(200);  
  
  End;
}
