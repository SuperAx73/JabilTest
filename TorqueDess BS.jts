//***********************************************************
//	FUNCTIONS
//***********************************************************
function Serial_Check()
{
	SetTestName("Serial Number Validation");
	$Fail_Text = StringCat("Extension de Numero de Serie Incorrecto","");
	Label TryScan:
	$SerialNumber = StringToUpper($SerialNumber);
	$SerialNumberLength = StringLength($SerialNumber);  

	if ($SerialNumber == "")		//Valida la longitud del numero de serie
	{
	$SerialNumber = OperatorInputPrompt("Escanee un numero de serie por favor");
	goto TryScan;
	}
	
	UpdateStatus("Serial Number Lenght OK...");  
	while (true)
	{
	$CAT01 = StringStartsWith($SerialNumber,"1", true);
	if($CAT01)
	{
		$FileNamePath ="C:\\JabilTest\\Config\\JabilTestVisualAidsBS-CAT1.csv";
		break;
	}
	$CATM = StringStartsWith($SerialNumber,"2", true);
	if($CATM)
	{
		$FileNamePath ="C:\\JabilTest\\Config\\JabilTestVisualAidsBS-CATM.csv";
		break;
	}
	
	$SerialNumber = OperatorInputPrompt("No se encontro archivo con ese serial, intente de nuevo.");

	}
	Label OKpath:
  return;
}

function StartAssy()
{

	($TotalSteps, $ObjStepDataList)=TorqueLoadExcel($FileNamePath);

    $ResultStatus= "El # de steps es de" + $TotalSteps;
    //~ OperatorPrompt($ResultStatus,"OK");
	
  $iCurrStep=1;
  $iPosition = 0;
  $sFmtMsg= "Iniciando ensamble, Total de Steps=" + $TotalSteps;
  UpdateStatus($sFmtMsg);  
  
  
      while( $iCurrStep<$TotalSteps )
	{
	  call UpdateStepInformation();
	  call DisplayVisualAidOperatorPrompt_IfApply();    
	  //~ call MoveTray_IfApply();
	  call TorqueTest_IfApply();
	  //Increment step number
	  $iCurrStep= $iCurrStep + 1;
	
      
	}
	
  return;
}


function UpdateStepInformation()
{
 //~ SerialPurge($SerialPortTorA);    
  //Get step information to know how to proceed
  ($iStepNumberReturned, $sImageFileName, $sHasTorque, $fTorque, $fMinTorque, $fMaxTorque, $iTrayPosition, $sMoveTray, $sApplyAngularTorque, $QtyScrewsByStep, $AngularDesoutterCycle, $sStepName)=TorqueGetStepInfo($iCurrStep,  $ObjStepDataList);


  //Confirm step number specified is the same than returned
  if( $iCurrStep != $iStepNumberReturned )
  {
    UpdateStatus("Step specificado NO es el mismo que regreso lista de arreglos");
    $sFmtMsg = "El número de Step specificado no es el mismo al regresado por arreglo de steps, el programa va a terminar";
    OperatorPrompt($sFmtMsg, "OK");
    End;
  }
    
  SetTestName($sStepName);    
  $sFmtMsg = "Step Num=" + $iStepNumberReturned + ", StepName=" + $sStepName;
  UpdateStatus($sFmtMsg);  
  $sFmtMsg = "ImageName=" + $sImageFileName;
  UpdateStatus($sFmtMsg); 
  return;  
}

function DisplayVisualAidOperatorPrompt_IfApply()
{
  
  if($sHasTorque == "No" || $sHasTorque =="NO")
  {
    Label RetryEtiquetas:
    $ButtonText = OperatorPicturePromptSpecifyOptionsWithPosition($sStepName, $sImageFileName, "STRETCH", 850, 1750, "PASA;", 10, 30);
     if ($sImageFileName =="C:\\JabilTest\\imagenes\\CAT1\\Slide1.png" || $sImageFileName =="C:\\JabilTest\\imagenes\\CATM\\Slide1.png")
     {
    UpdateStatus("chequeo de etiquetas");
    $sFmtMsg = "Introduce por favor cuantas etiquetas colocaste";
    $qetiquetas = OperatorInputPrompt($sFmtMsg);
     }
     if ($qetiquetas != "3")
     {
       $sFmtMsg = "No son las etiquetas correctas, intentelo de nuevo";
       OperatorPrompt($sFmtMsg, "OK");
       goto RetryEtiquetas;
     }
    if ($sImageFileName =="C:\\JabilTest\\imagenes\\CAT1\\Slide2.png" || $sImageFileName =="C:\\JabilTest\\imagenes\\CATM\\Slide2.png")
     {
    UpdateStatus("chequeo de patas");
    $sFmtMsg = "Introduce por favor cuantas patas colocaste";
    $qpatas = OperatorInputPrompt($sFmtMsg);
      if ($qpatas != "3")
       {
	 $sFmtMsg = "No son las etiquetas correctas, intentelo de nuevo";
	 OperatorPrompt($sFmtMsg, "OK");
	 goto RetryEtiquetas;
       }
     }
	    if($ButtonText == "PASA")      
		{
	    RecordMeasurementPassFail($sStepName, true,"Bool", false,true);
		}
		
  }
  
  return;  
}


function TorqueTest_IfApply()
{
   if($sHasTorque == "Yes" || $sHasTorque =="YES")
   {
      $sFmtMsg = "Torque test, StepNum=" + $iCurrStep + ", StepName=" + $sStepName + ", Torque Nominal=" + $fTorque ; 
      //~ OperatorPrompt($sFmtMsg,"OK"); 
      UpdateStatus($sFmtMsg);
      call Torque_Test();
      RecordMeasurement($sStepName, $Value, "InLb", false);
      RecordMeasurementPassFail($sStepName, $Value,"InLb", true,true);     
   }
   
  return;   
}

function Torque_Test()
   {
	
    $Fail_Text = StringCat("Falla en funcion Torque","");
    UpdateStatus("\r\n Screw Step =================================");  
      
	$TorqueAttempt = New ("Integer",0);	//Inicializacion de los intentos para instalar un tornillo
	   
	  Label RetryTorquea:
      $FImagePath = $sImageFileName;
      $ShowImage_handle = ShowImage($FImagePath,$Width,$Height);	//Desplega al operador una imagen del tornillo a instalar

  
	  $Fail_Text = StringCat("Error al abrir el puerto serial","");
	  $comPort = Serial_Open(20 ,9600,8,"N",1); //Abrir puerto con el que se cominucara
	  SleepMilliseconds(200); //Esperamos 200 milisegundosss

	  $TTAString1 = New ("String","");
	  $Fail_Text = StringCat("Error al obtener la lectura del torque","");
	  $TTAString1 = Serial_SendMilliseconds($comPort,"","\n",900000);		//Se espera de respuesta un 5C 6E, comando que se manda para que nos le da lectura de torque, espera 900 segundos = 15 min
	  $TTAString1 = StringTrim($TTAString1);					//Corta los espacios que contenga la respuesta
	  UpdateStatus($TTAString1);
	  
	  $Fail_Text = StringCat("Error al cerrar el puerto serie","");
	  Serial_Close($comPort);  //Cerramos el puerto donde leemos
	  SleepMilliseconds(200); 
	  $Value = StringSub($TTAString1,33,6);		//Corta 4 caracteres a partir del numero 24 para obtener el valor del torque
	  $Value = StringParseToFloat($Value);           //Lo comvertimos en flotante
	  
	  ///******************************PRUEBAS SIN TORQUE*****************************
	  
	  //~ $Value = OperatorInputPrompt("ingrese","OK");

	  //~ OperatorPrompt($LowLimit,"OK");
	  //~ OperatorPrompt($HighLimit,"OK");
	  //~ OperatorPrompt($Value,"OK");
	  
	  ///******************************PRUEBAS SIN TORQUE*****************************  

	  if(($Value < $fMinTorque) || ($Value > $fMaxTorque))		//Evalua los limites del torque si estan dentro de lo que se necesita
	  {
		$Fail_Text = StringCat("Medicion del torque incorrecta","");
		HideImage($ShowImage_handle);		//Cierra la imagen del tornillo a instalar
		$ImageFailed = $MainPath +"Fail.png";
		$ShowImage_handle = ShowImage($ImageFailed,350,350);	//Desplega al operador una imagen del tornillo a instalar
		Sleep(1);
		HideImage($ShowImage_handle);		//Cierra la imagen del tornillo a instalar
		RecordMeasurement("Torque value attempt",$Value,"Lbs-in",true);		//Registra el valor de torque tambien para las fallas sin evaluarlo
		
		$TorqueAttempt = $TorqueAttempt + 1 ;
		if ($TorqueAttempt < $TorqueAttemptLimit)		//Evalua los intentos para instalar un tornillo
		{
		  goto RetryTorquea;
		}
		
		if ($TorqueAttempt == $TorqueAttemptLimit)		//Evalua los intentos para instalar un tornillo
		{
			$AbortMessage = "Limite de intentos superado";
			$mensaje = OperatorPromptNonBlocking($AbortMessage,600, 600);
			Sleep(5);
			CloseForm($mensaje)	
			Abort($AbortMessage);
			
		}
	  }

	HideImage($ShowImage_handle);		//Cierra la imagen del tornillo a instalar	  
	$TorqueAttempt =0;
    Label ExitTorqueTesta:
    return;  
  }

function Configure_MES()
{
	  EnterCS("Report");
	  ($month,$day,$year,$hour,$min,$sec,$dayOfWeek) = SystemTime();
	  $NewLocation1 = "C:\\JabilEye\\mes\\" + $month + "_" + $year + "\\";	//Ruta para respaldo de datos 
      $NewLocation2 = "\\\\mxchim0pool02\\Ford\\Torque\\";
	  $NewLocation3 = "C:\\JabilEye\\html\\" + $month + "_" + $year + "\\";	//Ruta para respaldo de datos 
	  MESReportWriter_ConfigureLocations($NewLocation1,$NewLocation2,true); //Crea reporte a mes en localidad 1 
	  HtmlReportWriter_ConfigureLocations($NewLocation3, $NewLocation3, true);
	  $Exists = CheckDirectoryExists($NewLocation1);
		  if (!$Exists)
		  {
		CreateDirectory($NewLocation1);
		  }
		  
	  ExitCS("Report");
	  ConfigureReporting("MESReportWriter.dll" ,true);		//Se habilita el reporte HTML
	  ConfigureReporting("HTMLReportWriter.dll" ,true);		//Se habilita el reporte HTML
      

		
  return;
}

